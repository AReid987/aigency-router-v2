# === Environment Variables for Aigency Gateway ===
# Copy this file to .env and adjust values for your deployment.
# See docs/OPERATIONS.md for full documentation.

# === Rate Limiting ===
GATEWAY_RATE_LIMITING=false
GATEWAY_RATE_LIMIT_TOKENS=100
GATEWAY_RATE_LIMIT_WINDOW_MS=60000

# === Admin Auth ===
GATEWAY_ADMIN_AUTH=false
GATEWAY_ADMIN_TOKEN=  # generate via: openssl rand -hex 32

# === Quota Monitoring ===
GATEWAY_QUOTA_MONITORING=false

# === Zero-Cost Enforcement ===
GATEWAY_ZERO_COST_ENFORCEMENT=false
GATEWAY_ZERO_COST_DB_PATH=./data/usage.db
GATEWAY_ZERO_COST_GROQ_LIMIT=1000
GATEWAY_ZERO_COST_CEREBRAS_LIMIT=500
GATEWAY_ZERO_COST_TOGETHER_LIMIT=800

# === Pipeline ===
GATEWAY_USE_ENGRAM_PIPELINE=false

# === Service URLs ===
GATEWAY_VAULT_URL=http://127.0.0.1:8082
GATEWAY_SUGAR_DB_URL=http://127.0.0.1:8081


# === Health and Dashboard ===
GATEWAY_HEALTH_PORT=9090
GATEWAY_COST_REPORTING=false
GATEWAY_DASHBOARD=false
GATEWAY_DASHBOARD_STREAM=false

# === Cost Tracking ===


# === Provider Tuning ===


# === Logging ===
LOG_LEVEL=info

